#!/bin/bash
cd "$(dirname "$0")"
source venv/bin/activate

echo "Choose mode:"
echo "1 - Manual search"
echo "2 - Automatic search"
read choice

if [ "$choice" = "1" ]; then
    python3 google.py
elif [ "$choice" = "2" ]; then
    python3 googleauto.py
else
    echo "Invalid choice"
fi

read -p "Press Enter to close..."
