import re
import time
import requests

phone_columns = ["GSM", "TEL1", "TEL2", "TEL3"]

def clean_number(value):
    if pd.isna(value):
        return ""
    return re.sub(r"\D", "", str(value))

def is_valid_belgian_tva(number):
    """
    Belgian TVA/KBO = 10 digits.
    Format can start with 0 or 1.
    Checksum: 97 - first 8 digits % 97 = last 2 digits
    """
    number = clean_number(number)

    if len(number) == 9:
        number = "0" + number

    if len(number) != 10:
        return False, ""

    first_8 = int(number[:8])
    check_2 = int(number[8:])
    valid_check = 97 - (first_8 % 97)

    if valid_check == check_2:
        return True, number

    return False, number

