# Make CP a string and remove spaces
master["CP"] = master["CP"].astype(str).str.strip()

# Keep only digits for checking
cp_clean = master["CP"].str.replace(r"\D", "", regex=True)

# Find CPs that are NOT exactly 4 digits
cp_invalid = master[cp_clean.str.len() != 4]

# Save invalid CPs to a separate file
cp_invalid.to_excel("CP_invalid.xlsx", index=False)

print("Invalid CP rows:", len(cp_invalid))
