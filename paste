import pandas as pd
import glob
import os

folder_path = r"C:\Users\Sunlight\Desktop\test"

files = [
    f for f in glob.glob(os.path.join(folder_path, "*.xlsx"))
    if not os.path.basename(f).startswith("~$")
]

all_dfs = []

for file in files:
    print("Reading:", os.path.basename(file))
    df = pd.read_excel(file)
    all_dfs.append(df)

merged_df = pd.concat(all_dfs, ignore_index=True)

output_file = os.path.join(folder_path, "merged_file.xlsx")
merged_df.to_excel(output_file, index=False)

print("DONE")
print("Output:", output_file)
print("Rows:", len(merged_df))
