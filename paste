def find_candidates_safe(row):
    candidates = []

    # Search only places where TVA is more likely
    for col in ["TVA", "OTHER_INFO"]:
        value = row.get(col)

        if pd.isna(value):
            continue

        numbers = re.findall(r"\d{9,10}", str(value))

        for num in numbers:
            candidates.append("BE" + num.zfill(10))

    return list(dict.fromkeys(candidates))







