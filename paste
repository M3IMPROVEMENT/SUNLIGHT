import requests
import time

# ==========================
# CHECK TVA USING KBO API
# ==========================

API_TOKEN = "PUT_YOUR_KBO_API_KEY_HERE"
BASE_URL = "https://api.kbodata.app/v2"

check_columns = ["GSM", "TEL1", "TEL2", "TEL3"]

def clean_number(value):
    if pd.isna(value):
        return ""

    value = str(value).strip().upper()
    value = value.replace("BE", "")
    value = value.replace(".0", "")

    for ch in [" ", ".", "-", "/", "+", "(", ")"]:
        value = value.replace(ch, "")

    return value


def looks_like_tva(value):
    value = clean_number(value)
    return len(value) == 10 and value.isdigit() and value[0] in ["0", "1"]


def kbo_exists(value):
    value = clean_number(value)

    if not looks_like_tva(value):
        return False

    url = f"{BASE_URL}/enterprise/{value}"
    headers = {
        "Authorization": f"Bearer {API_TOKEN}"
    }

    try:
        response = requests.get(url, headers=headers, timeout=10)

        if response.status_code == 200:
            return True

        if response.status_code == 404:
            return False

        print("API problem:", response.status_code, value)
        return False

    except Exception as e:
        print("Error checking:", value, e)
        return False


wrong_tva_rows = []
keep_rows = []

for idx, row in master.iterrows():
    tva_value = row["TVA"]

    # 1. Check TVA column first
    if kbo_exists(tva_value):
        keep_rows.append(idx)
        continue

    # 2. If TVA is not valid, check GSM/TEL columns
    found_tva_in_wrong_column = False

    for col in check_columns:
        value = row[col]

        if kbo_exists(value):
            found_tva_in_wrong_column = True
            break

    if found_tva_in_wrong_column:
        wrong_tva_rows.append(idx)
    else:
        keep_rows.append(idx)

    time.sleep(0.2)

# Separate wrong rows
tva_wrong = master.loc[wrong_tva_rows].copy()

# Keep only clean rows
master = master.loc[keep_rows].copy()

# Save wrong TVA rows
tva_wrong.to_excel("TVA_wrong_column_KBO.xlsx", index=False)

print("TVA wrong rows:", len(tva_wrong))
print("Rows remaining in master:", len(master))
