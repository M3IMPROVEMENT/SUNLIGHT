import pandas as pd
import os
import glob
import re

# Folder containing your original Excel files
input_folder = r"C:\Users\Sunlight\Desktop\DOSSIE 17-06-2026\1-2-3.xlsl"

# New folder where corrected copies will be saved
output_folder = r"C:\Users\Sunlight\Desktop\DOSSIE 17-06-2026\GSM\\GSM_FIXE"

# Create the output folder if it does not exist
os.makedirs(output_folder, exist_ok=True)

# Columns that will be checked
phone_columns = ["GSM", "TEL1", "TEL2", "TEL3"]


def clean_for_check(value):
    """
    Clean the number only for classification.
    The original number will remain unchanged in the output.
    """
    if pd.isna(value):
        return ""

    number = str(value).strip()

    # Remove .0 or .000000 added by Excel
    number = re.sub(r"\.0+$", "", number)

    # Keep digits only
    number = re.sub(r"\D", "", number)

    return number


def classify_phone(value):
    """
    Classification after temporarily removing:
    - 0032
    - 32
    - one leading 0

    After removing the prefix:
    - 9 digits = GSM
    - 8 digits = FIXE
    """
    number = clean_for_check(value)

    if number == "":
        return ""

    # Remove Belgian prefixes only for checking
    if number.startswith("0032"):
        number = number[4:]

    elif number.startswith("32"):
        number = number[2:]

    elif number.startswith("0"):
        number = number[1:]

    if len(number) == 9:
        return "GSM"

    if len(number) == 8:
        return "FIXE"

    return "UNKNOWN"


def original_number_as_text(value):
    """
    Return the original number as text.
    Only removes Excel's .0 ending.
    """
    if pd.isna(value):
        return ""

    number = str(value).strip()
    number = re.sub(r"\.0+$", "", number)

    return number


def add_correct_phone_columns(df):
    # Clean column names
    df.columns = df.columns.astype(str).str.strip().str.upper()

    correct_gsm_values = []
    fixe_values = []

    for _, row in df.iterrows():

        gsm_numbers = []
        fixe_numbers = []

        for column in phone_columns:

            if column not in df.columns:
                continue

            value = row[column]

            if pd.isna(value) or str(value).strip() == "":
                continue

            phone_type = classify_phone(value)
            original_number = original_number_as_text(value)

            if phone_type == "GSM":
                if original_number not in gsm_numbers:
                    gsm_numbers.append(original_number)

            elif phone_type == "FIXE":
                if original_number not in fixe_numbers:
                    fixe_numbers.append(original_number)

        correct_gsm_values.append(" ; ".join(gsm_numbers))
        fixe_values.append(" ; ".join(fixe_numbers))

    # Add the two new columns at the end
    df["CORRECT_GSM"] = correct_gsm_values
    df["FIXE"] = fixe_values

    return df


# Find all Excel files
excel_files = (
    glob.glob(os.path.join(input_folder, "*.xlsx"))
    + glob.glob(os.path.join(input_folder, "*.xls"))
)

if not excel_files:
    print("No Excel files were found in the input folder.")

else:
    for input_file in excel_files:

        filename = os.path.basename(input_file)

        # Ignore temporary Excel files
        if filename.startswith("~$"):
            continue

        # Always save as .xlsx
        output_name = os.path.splitext(filename)[0] + "_GSM_FIXE.xlsx"
        output_file = os.path.join(output_folder, output_name)

        print("Processing:", filename)

        try:
            # Read all sheets
            sheets = pd.read_excel(
                input_file,
                sheet_name=None,
                dtype=object
            )

            with pd.ExcelWriter(
                output_file,
                engine="openpyxl"
            ) as writer:

                for sheet_name, df in sheets.items():

                    corrected_df = add_correct_phone_columns(df.copy())

                    corrected_df.to_excel(
                        writer,
                        sheet_name=str(sheet_name)[:31],
                        index=False
                    )

            print("Saved:", output_file)

        except PermissionError:
            print("Permission error:", filename)
            print("Close the Excel file and run the code again.")

        except Exception as error:
            print("Error in file:", filename)
            print(error)

    print("\nDONE")
    print("Original files were not modified.")
    print("New files are saved in:")
    print(output_folder)
