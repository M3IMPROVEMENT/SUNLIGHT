valid_tvas = set(
    checked_df.loc[checked_df["IS_VALID_KBO"], "TVA_CANDIDATE"]
)

# Start with already clean BE TVA
final_df["TVA_FINAL"] = final_df["TVA_BE_CLEAN"]

# Only process rows where TVA_BE_CLEAN is missing
mask = final_df["TVA_FINAL"].isna()

def choose_from_candidates(candidates):
    if pd.isna(candidates) or candidates == "":
        return None

    for candidate in str(candidates).split(", "):
        if candidate in valid_tvas:
            return candidate

    return None

final_df.loc[mask, "TVA_FINAL"] = final_df.loc[mask, "TVA_CANDIDATES"].apply(
    choose_from_candidates
)

final_df["TVA"] = final_df["TVA_FINAL"]

final_df.drop(columns=["TVA_FINAL"], inplace=True)

print("Final valid TVA:", final_df["TVA"].notna().sum())
